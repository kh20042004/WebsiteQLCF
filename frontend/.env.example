/**
 * File: .env.example - Mẫu biến môi trường cho Frontend
 * 
 * Hướng dẫn:
 * 1. Copy file này thành .env
 * 2. Cập nhật giá trị theo cấu hình của bạn
 * 3. Không commit .env để giữ bí mật
 */

# ---- API ----
# Địa chỉ backend server
REACT_APP_API_BASE_URL=http://localhost:3000

# ---- ENVIRONMENT ----
# development hoặc production
REACT_APP_ENV=development

# ---- DEBUG ----
# Bật/tắt debug mode
REACT_APP_DEBUG=true
